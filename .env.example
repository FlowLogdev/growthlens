# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # production: https://usegrowthlens.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Meta (your app-level credentials — same app serves all customers)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=          # e.g. https://usegrowthlens.com/api/oauth/meta/callback

# TikTok (your app-level credentials)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=        # e.g. https://usegrowthlens.com/api/oauth/tiktok/callback

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=

# Resend
RESEND_API_KEY=

# Cron protection
CRON_SECRET=

# Token encryption (generate with: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=
